# =============================================================================
# AI-Powered Adaptive Competitive Programming Platform
# Environment Variables — Copy this file to .env and fill in real values
# =============================================================================

# -----------------------------------------------------------------------------
# Layer 5: PostgreSQL (Primary Application Database)
# -----------------------------------------------------------------------------
POSTGRES_DB=competitive_platform
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=platform_secret
POSTGRES_PORT=5432

# Prisma connection string (used by backend)
DATABASE_URL=postgresql://platform_user:platform_secret@localhost:5432/competitive_platform?schema=public

# -----------------------------------------------------------------------------
# Layer 5: Redis (Cache, Sessions, Leaderboard, Rate Limits)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:redis_secret@localhost:6379

# -----------------------------------------------------------------------------
# Layer 2: Backend (Node.js + Express)
# -----------------------------------------------------------------------------
BACKEND_PORT=4000
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Layer 3: AI Service (Python + FastAPI)
# -----------------------------------------------------------------------------
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000

# Hugging Face — Used by LangChain for open-source LLM inference
HUGGINGFACE_API_KEY=hf_your_api_key_here

# -----------------------------------------------------------------------------
# Layer 4: Judge0 CE (Code Execution Sandbox)
# -----------------------------------------------------------------------------
JUDGE0_PORT=2358
JUDGE0_API_URL=http://localhost:2358
# If using RapidAPI Judge0, provide your key here and set URL to https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your_rapidapi_key_here

# Judge0 Isolated Database
JUDGE0_DB_NAME=judge0
JUDGE0_DB_USER=judge0
JUDGE0_DB_PASSWORD=judge0_secret
JUDGE0_DB_PORT=5433

# -----------------------------------------------------------------------------
# Layer 1: Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=CodeForge
